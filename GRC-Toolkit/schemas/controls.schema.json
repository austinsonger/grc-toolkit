{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Controls Dataset",
  "$defs": {
    "PossibleSolutions": {
      "type": "object",
      "required": ["micro_small", "small", "medium", "large", "enterprise"],
      "properties": {
        "micro_small": {"type": "array", "items": {"type": "string"}},
        "small": {"type": "array", "items": {"type": "string"}},
        "medium": {"type": "array", "items": {"type": "string"}},
        "large": {"type": "array", "items": {"type": "string"}},
        "enterprise": {"type": "array", "items": {"type": "string"}}
      }
    },
    "grctoolkitControl": {
      "type": "object",
      "required": [
        "source_row",
        "control_id",
        "control_domain",
        "control_name",
        "control_description",
        "cadence",
        "evidence_request_list",
        "framework_refs",
        "possible_solutions",
        "control_question",
        "applicability",
        "nist_csf_function_grouping"
      ],
      "properties": {
        "source_row": {"type": "integer", "minimum": 1},
        "control_id": {"type": "string", "pattern": "^[A-Z]{2,6}-[0-9]{2}(\\.[0-9]{1,3})?$"},
        "control_domain": {"type": "string"},
        "control_name": {"type": "string"},
        "control_description": {"type": "string"},
        "cadence": {"type": "string", "enum": ["Annual", "Quarterly", "Semi-Annual"]},
        "evidence_request_list": {"type": "array", "items": {"type": "string"}},
        "framework_refs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["framework", "controls"],
            "properties": {
              "framework": {"type": "string"},
              "controls": {"type": "array", "items": {"type": "string"}}
            }
          }
        },
        "possible_solutions": {"$ref": "#/$defs/PossibleSolutions"},
        "control_question": {"type": "string"},
        "relative_control_weighting": {"type": ["integer", "null"], "minimum": 1},
        "applicability": {"type": "string", "enum": ["Data", "Facility", "N/A", "People", "Process", "Technology"]},
        "nist_csf_function_grouping": {"type": "string", "enum": ["Detect", "Govern", "Identify", "Protect", "Recover", "Respond"]}
      }
    },
    "setTheoryRelationship": {
      "type": "object",
      "required": ["relation", "source_scope", "target_scope"],
      "properties": {
        "relation": {
          "type": "string",
          "enum": ["equal", "equivalent", "subset_of", "subset", "superset_of", "superset", "intersects_with", "intersection", "overlap", "no_relationship", "disjoint"],
          "description": "Set-theory relation following NIST IR 8477. Canonical values: equal, subset_of, superset_of, intersects_with, no_relationship; legacy aliases are retained for compatibility."
        },
        "source_scope": {
          "type": "string",
          "enum": [
            "framework_control_set",
            "normalized_control_set",
            "control_requirement_set",
            "risk_scenario_set",
            "implementation_evidence_set"
          ]
        },
        "target_scope": {
          "type": "string",
          "enum": [
            "framework_control_set",
            "normalized_control_set",
            "control_requirement_set",
            "risk_scenario_set",
            "implementation_evidence_set"
          ]
        },
        "confidence_alignment": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "rationale": {
          "type": "string",
          "enum": ["syntactic", "semantic", "functional"],
          "description": "IR 8477 rationale type for this relation: syntactic, semantic, or functional."
        }
      }
    }
  },
  "type": "object",
  "required": ["version", "generated_at", "controls"],
  "properties": {
    "version": {"type": "string"},
    "generated_at": {"type": "string"},
    "controls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["control_id", "title", "description", "domain", "framework_refs", "risk_ids"],
        "properties": {
          "control_id": {"type": "string", "pattern": "^CTRL-[A-Z]{2,5}-[0-9]{3}$"},
          "title": {"type": "string"},
          "description": {"type": "string"},
          "domain": {"type": "string"},
          "framework_refs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["framework", "controls"],
              "properties": {
                "framework": {"type": "string"},
                "controls": {"type": "array", "items": {"type": "string"}}
              }
            }
          },
          "risk_ids": {"type": "array", "items": {"type": "string"}},
          "owners": {"type": "array", "items": {"type": "string"}},
          "set_theory_relationships": {
            "type": "array",
            "description": "Optional IR 8477-aligned set relations for control-to-control or control-to-risk semantics.",
            "items": {"$ref": "#/$defs/setTheoryRelationship"}
          }
        }
      }
    },
    "grctoolkit_controls": {
      "type": "array",
      "items": {"$ref": "#/$defs/grctoolkitControl"}
    }
  }
}
